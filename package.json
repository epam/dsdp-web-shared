{
  "name": "web-shared-lib",
  "version": "0.1.0",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "scripts"
  ],
  "engines": {
    "node": ">=14.5",
    "npm": ">=7"
  },
  "scripts": {
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:coverage:dev": "vitest run --coverage --coverage.reporter=text",
    "test:coverage:win": "vitest --coverage",
    "lint": "eslint --ext .ts --ext .tsx src",
    "onlyLint": "npx oxlint && npm run lint"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "devDependencies": {
    "@types/react-redux": "7.1.23",
    "@vitest/coverage-v8": "3.2.4",
    "eslint-plugin-oxlint": "1.33.0",
    "oxlint": "1.33.0",
    "reapop": "4.0.5"
  },
  "dependencies": {
    "@material-ui/core": "4.12.4",
    "@reduxjs/toolkit": "1.9.0",
    "@testing-library/jest-dom": "6.5.0",
    "@testing-library/react": "14.3.1",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "eslint": "8.57.1",
    "history": "5.3.0",
    "i18next": "20.6.1",
    "js-cookie": "3.0.5",
    "lodash": "4.18.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-redux": "7.2.6",
    "react-router": "7.13.0",
    "redux": "4.1.2",
    "redux-observable": "1.2.0",
    "rxjs": "7.5.4",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
